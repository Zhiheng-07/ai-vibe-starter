# =============================================================================
# Environment variable TEMPLATE — this file IS committed to Git.
# It contains keys + placeholder values ONLY. Never put real secrets here.
#
# To start working:  copy this file to .env.local and fill in real values.
#   cp .env.example .env.local   (or run: npm run setup)
# =============================================================================

# --- Public (safe to expose to the browser; must be prefixed NEXT_PUBLIC_) ---
NEXT_PUBLIC_APP_NAME="ai-vibe-starter"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC_) ---
# Example database connection string:
DATABASE_URL="postgresql://user:password@localhost:5432/app_dev"

# Example third-party API key (replace with a real one in .env.local):
API_SECRET_KEY="replace-me-with-a-real-key"

# DeepSeek API key — used server-side by lib/summarize.ts to summarize + translate.
# Get one at https://platform.deepseek.com. Put the real key (starts with sk-) in
# .env.local only — NEVER commit it. Server-only, never expose to the browser.
DEEPSEEK_API_KEY="replace-me-with-a-real-deepseek-key"
